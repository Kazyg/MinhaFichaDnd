{
  "name": "fixa-rpg",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.1",
    "@testing-library/user-event": "^14.5.2",
    "react-router-dom": "^6.23.1",
    "react-scripts": "^5.0.1",
    "web-vitals": "^3.5.0"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build && npm run obfuscate",
    "obfuscate": "javascript-obfuscator ./build --output ./build --compact true --control-flow-flattening true",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "obfuscate": "javascript-obfuscator ./build --output ./build --compact true --control-flow-flattening true --dead-code-injection true --debug-protection true --debug-protection-interval true --disable-console-output true",
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "javascript-obfuscator": "^4.1.1",
    "typescript": "^4.9.5"
  }
}